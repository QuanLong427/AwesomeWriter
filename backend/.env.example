# =====================================================
# AwesomeWriter 环境变量配置
# 复制此文件为 .env 并填入实际值
# 敏感信息（API Key 等）请写在 .env.local 中
# =====================================================

# ---- 数据库 ----
# MySQL 连接字符串
DATABASE_URL="mysql://root:password@localhost:3306/awesomewriter"

# ---- AI 配置 ----
# 默认 AI 提供商: openai | claude | deepseek
AI_PROVIDER="openai"
# 默认模型（留空使用 provider 默认模型）
AI_MODEL=""
# API Key 请写在 .env.local 中：
#   OPENAI_API_KEY=sk-xxx
#   ANTHROPIC_API_KEY=sk-ant-xxx
#   DEEPSEEK_API_KEY=sk-xxx

# ---- 服务器 ----
PORT=3001
CORS_ORIGIN="http://localhost:5173"
